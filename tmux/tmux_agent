#!/bin/bash



if ! command -v tmux >/dev/null 2>&1; then
echo "tmux not installed"
return 1
fi

# Get the current directory name to include in session name
DIR_NAME=$(basename "$(pwd)")

# If session already exists, increment number until we find a free name
SESSION_NAME="agent_${DIR_NAME}"
SESSION_NUMBER=0
while tmux has-session -t "$SESSION_NAME" 2>/dev/null; do
    SESSION_NUMBER=$((SESSION_NUMBER + 1))
    SESSION_NAME="agent_${DIR_NAME}_${SESSION_NUMBER}"
done

# Create session + windows
tmux new-session -d -s "$SESSION_NAME" -n opencode
tmux new-window -t "$SESSION_NAME":2 -n nvim

tmux select-window -t "$SESSION_NAME":1

exec tmux attach -t "$SESSION_NAME"
